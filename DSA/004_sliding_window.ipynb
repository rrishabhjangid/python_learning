   "source": [
    "#Finding best 3 day streak\n",
    "nums = [2, 1, 5, 1, 3, 2]\n",
    "k=3\n",
    "\n",
    "sumk=0\n",
    "for i in range(k):\n",
    "    sumk+=nums[i]\n",
    "\n",
    "max_sum=sumk\n",
    "\n",
    "for i in range(k,len(nums)):\n",
    "    sumk+=nums[i]\n",
    "    sumk-=nums[i-k]\n",
    "    if sumk>max_sum:\n",
    "        max_sum=sumk\n",
    "print(max_sum)\n"
   ]
  },
