   "source": [
    "from collections import deque\n",
    "\n",
    "queue=deque()\n",
    "\n",
    "queue.append(10)\n",
    "queue.append(20)\n",
    "queue.append(30)\n",
    "\n",
    "print(queue)\n",
    "\n",
    "while len(queue)!=0:\n",
    "    queue.popleft()\n",
    "    print(queue)"
   ]
  },
