   "source": [
    "Reversing an array without .reverse() or [::-1]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 50,
   "id": "49e63462",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[10, 20, 30, 40, 50]\n"
     ]
    }
   ],
   "source": [
    "a1=[10,20,30,40,50]\n",
    "print(a1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 47,
   "id": "a3840040",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "0 4\n"
     ]
    }
   ],
   "source": [
    "left=0\n",
    "right=len(a1)-1\n",
    "print(left,right)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 49,
   "id": "61c788dd",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[50, 40, 30, 20, 10]\n"
     ]
    }
   ],
   "source": [
    "temp=None\n",
    "while left<right:\n",
    "    temp=a1[left]\n",
    "    a1[left]=a1[right]\n",
    "    a1[right]=temp\n",
    "    left+=1\n",
    "    right-=1\n",
    "print(a1)"
   ]
  },
